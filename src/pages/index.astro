---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import CarCard from '../components/CarCard.astro';
import carsData from '../data/cars.json';

// Get only first 6 cars for homepage
const featuredCars = carsData.slice(0, 6);

const services = [
  {
    icon: '/blmcars/assets/blm-icon1.png',
    title: 'Achat / Vente de Véhicules',
    description: 'Accédez à une sélection premium de voitures d\'occasion, méticuleusement inspectées et garanties, pour un achat en toute tranquillité.',
    link: '/achat',
    linkText: 'Voir nos véhicules'
  },
  {
    icon: '/blmcars/assets/blm-icon2.png',
    title: 'Solutions de Leasing',
    description: 'Profitez de la flexibilité de nos offres de financement. Nous concevons des solutions de leasing sur mesure, adaptées à vos besoins et à votre budget.',
    link: 'mailto:info@blmcars.ch',
    linkText: 'Contactez-nous'
  },
  {
    icon: '/blmcars/assets/blm-icon3.png',
    title: 'Mandat de Recherche',
    description: 'Vous avez un modèle précis en tête ? Confiez-nous votre recherche. Nous mettons notre réseau et notre expertise à votre service pour trouver la perle rare.',
    link: 'mailto:info@blmcars.ch',
    linkText: 'Contactez-nous'
  }
];

const faqs = [
  {
    question: 'Comment acheter une voiture ?',
    answer: 'Le processus est simple : parcourez notre sélection en ligne, contactez-nous pour un essai, et nous vous guiderons à travers les étapes de financement et d\'achat.'
  },
  {
    question: 'Quels documents sont nécessaires ?',
    answer: 'Généralement, une pièce d\'identité valide, un permis de conduire, et un justificatif de domicile sont nécessaires. Nous vous informerons de tout document supplémentaire requis.'
  },
  {
    question: 'Proposez-vous des garanties ?',
    answer: 'Oui, la plupart de nos véhicules bénéficient d\'une garantie. Les détails et la durée de la garantie varient selon le modèle et sont clairement indiqués sur chaque fiche véhicule.'
  }
];
---

<Layout>
  <Navbar />
  
  <main>
    <!-- Hero Section -->
    <section class="relative min-h-screen flex items-center overflow-hidden">
      <!-- Background Image with blue gradient overlay -->
      <div class="absolute inset-0 z-0">
        <img 
          src="/blmcars/blm-wallpaper.webp" 
          alt="BLM CARS Showroom" 
          class="w-full h-full object-cover object-center sm:object-right"
        />
        <div class="absolute inset-0 bg-gradient-to-r from-blue-900/80 via-blue-900/30 to-transparent"></div>
        <div class="absolute inset-0 bg-gradient-to-r from-black/80 via-black/30 to-transparent"></div>
        <div class="absolute inset-0 bg-gradient-to-t from-bg via-transparent to-transparent"></div>
      </div>
      
      <!-- Content -->
      <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 w-full pt-32 pb-20">
        <h1 class="text-4xl sm:text-5xl lg:text-6xl xl:text-7xl font-bold text-white mb-6 tracking-tight max-w-3xl">
          Achat & Vente de<br />
          <span class="text-primary">Voitures à Genève</span>
        </h1>
        <p class="text-lg sm:text-xl text-white/60 max-w-xl mb-10">
          Découvrez notre sélection de véhicules d'occasion, rigoureusement inspectés pour une performance et une fiabilité sans compromis.
        </p>
        <div class="flex flex-col sm:flex-row items-start gap-4">
          <a 
            href="/blmcars/achat" 
            class="inline-flex items-center px-8 py-4 text-base font-semibold text-bg bg-primary rounded-xl hover:bg-primary/90 transition-all duration-200"
          >
            Nos Voitures
          </a>
          <a 
            href="#services" 
            class="inline-flex items-center px-8 py-4 text-base font-semibold text-white border border-white/20 rounded-xl hover:bg-white/5 transition-all duration-200"
          >
            Nos Services
          </a>
        </div>
      </div>
      
      <!-- Scroll Indicator -->
      <div class="absolute bottom-8 left-1/2 -translate-x-1/2 z-10 animate-bounce">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-white/50" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
        </svg>
      </div>
    </section>

    <!-- Nos Voitures Section -->
    <section id="cars" class="py-20 lg:py-28">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-14">
          <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-white mb-4">
            Nos Voitures
          </h2>
          <p class="text-text-secondary text-lg max-w-2xl mx-auto">
            Une sélection de véhicules rigoureusement inspectés et prêts à partir.
          </p>
        </div>
        
        <!-- Cars Grid -->
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8">
          {featuredCars.map(car => (
            <CarCard car={car} />
          ))}
        </div>
        
        <!-- View All Button -->
        <div class="text-center mt-12">
          <a 
            href="/blmcars/achat" 
            class="inline-flex items-center gap-2 px-8 py-4 text-base font-semibold text-primary border border-primary/30 rounded-xl hover:bg-primary/10 transition-all duration-200"
          >
            Voir tous nos véhicules
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>
        </div>
      </div>
    </section>

    <!-- Qui Sommes-nous Section -->
    <section id="about" class="py-20 lg:py-28 bg-card">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center">
          <!-- Image -->
          <div class="relative">
            <div class="aspect-[4/3] rounded-2xl overflow-hidden">
              <img 
                src="/blmcars/assets/BLM Cars - Vitrine.jpg" 
                alt="BLM CARS Showroom" 
                class="w-full h-full object-cover"
              />
            </div>
            <!-- Decorative element -->
            
          </div>
          
          <!-- Content -->
          <div>
            <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-white mb-6">
              Qui sommes-nous ?
            </h2>
            <div class="space-y-4 text-text-secondary text-base leading-relaxed">
              <p>
                Bienvenue chez <strong class="text-white">B.L.M. CARS</strong>, votre partenaire de confiance pour l'achat et la vente de voitures à Genève. Forts de plus de <strong class="text-white">15 ans d'expérience</strong> dans le secteur automobile, nous nous engageons à offrir un service de premier ordre à chacun de nos clients.
              </p>
              <p>
                En tant que professionnels passionnés, nous garantissons une expertise inégalée. Notre approche personnalisée et notre attention aux détails nous permettent de répondre aux besoins spécifiques de chaque client, assurant ainsi une expérience sans faille.
              </p>
            </div>
            <div class="mt-8 flex items-center gap-8">
              <div>
                <div class="text-4xl font-bold text-primary">15+</div>
                <div class="text-sm text-text-secondary">Années d'expérience</div>
              </div>
              <div class="w-px h-12 bg-white/10"></div>
              <div>
                <div class="text-4xl font-bold text-primary">500+</div>
                <div class="text-sm text-text-secondary">Clients satisfaits</div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Services Section -->
    <section id="services" class="py-20 lg:py-28">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-14">
          <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-white mb-4">
            Nos services sur mesure
          </h2>
          <p class="text-text-secondary text-lg max-w-2xl mx-auto">
            Des solutions complètes et personnalisées pour concrétiser votre projet automobile avec sérénité et confiance.
          </p>
        </div>
        
        <!-- Services Grid -->
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          {services.map(service => (
            <div class="group bg-card rounded-2xl p-8 border border-white/5 hover:border-primary/20 transition-all duration-300">
              <!-- Icon -->
              <div class="w-16 h-16 mb-6 flex items-center justify-center">
                <img src={service.icon} alt={service.title} class="w-10 h-10 object-contain" />
              </div>
              
              <!-- Content -->
              <h3 class="text-xl font-semibold text-white mb-4">
                {service.title}
              </h3>
              <p class="text-text-secondary text-sm leading-relaxed mb-6">
                {service.description}
              </p>
              
              <!-- Link -->
              <a 
                href={service.link}
                class="inline-flex items-center gap-2 text-primary font-medium text-sm hover:gap-3 transition-all duration-200"
              >
                {service.linkText}
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                </svg>
              </a>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- FAQ Section -->
    <section id="faq" class="py-20 lg:py-28 bg-card">
      <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-14">
          <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-white mb-4">
            FAQ
          </h2>
          <p class="text-text-secondary text-lg">
            Les questions de nos clients les plus fréquentes !
          </p>
        </div>
        
        <!-- FAQ Items -->
        <div class="space-y-4">
          {faqs.map((faq, index) => (
            <details class="group bg-bg rounded-xl border border-white/5 overflow-hidden">
              <summary class="flex items-center justify-between p-6 cursor-pointer list-none">
                <span class="text-white font-medium text-left pr-4">{faq.question}</span>
                <span class="flex-shrink-0 w-8 h-8 flex items-center justify-center text-white/40 group-open:text-primary transition-colors duration-200">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 transition-transform duration-200 group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                  </svg>
                </span>
              </summary>
              <div class="px-6 pb-6 text-text-secondary text-sm leading-relaxed">
                {faq.answer}
              </div>
            </details>
          ))}
        </div>
        
        <!-- Contact CTA -->
        <div class="mt-12 text-center p-8 bg-primary/5 rounded-2xl border border-primary/10">
          <h3 class="text-xl font-semibold text-white mb-2">
            Vous avez d'autres questions ?
          </h3>
          <p class="text-text-secondary mb-6">
            Contactez-nous sans attendre
          </p>
          <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
            <a 
              href="mailto:info@blmcars.ch" 
              class="inline-flex items-center gap-2 px-6 py-3 text-sm font-semibold text-bg bg-primary rounded-xl hover:bg-primary/90 transition-all duration-200"
            >
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
              </svg>
              info@blmcars.ch
            </a>
            <a 
              href="tel:+41795644449" 
              class="inline-flex items-center gap-2 px-6 py-3 text-sm font-semibold text-white border border-white/20 rounded-xl hover:bg-white/5 transition-all duration-200"
            >
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
              </svg>
              +41 79 564 44 49
            </a>
          </div>
        </div>
      </div>
    </section>
  </main>
  
  <Footer />
</Layout>
