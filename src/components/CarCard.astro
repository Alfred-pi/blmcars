---
interface Props {
  car: {
    id: number;
    make: string;
    model: string;
    year: string;
    month: string;
    fuel: string;
    mileage: string;
    transmission: string;
    price: string;
    images: string[];
    url: string;
  };
}

const { car } = Astro.props;
const fullName = `${car.make} ${car.model}`;
const mainImage = car.images?.[0] || '';
const imageCount = car.images?.length || 0;
---

<a 
  href={car.url}
  target="_blank"
  rel="noopener noreferrer"
  class="group block bg-card rounded-2xl overflow-hidden transition-all duration-500 ease-out hover:scale-[0.98] border border-white/5"
>
  <!-- Image -->
  <div class="relative aspect-[4/3] overflow-hidden">
    <img 
      src={mainImage} 
      alt={fullName}
      class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
      loading="lazy"
      onerror="this.src='https://placehold.co/600x400/0a0a0a/666?text=BLM+CARS'"
    />
    <div class="absolute inset-0 bg-gradient-to-t from-card/80 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
    
    <!-- Image counter badge -->
    {imageCount > 1 && (
      <div class="absolute top-3 right-3 text-white text-xs flex items-center gap-1 drop-shadow-md">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
        </svg>
        {imageCount}
      </div>
    )}
  </div>
  
  <!-- Content -->
  <div class="p-5">
    <!-- Title -->
    <h3 class="text-white font-semibold text-base mb-3 line-clamp-2 min-h-[48px]">
      {fullName.toUpperCase()}
    </h3>
    
    <!-- Specs Grid -->
    <div class="grid grid-cols-2 gap-y-2 gap-x-4 text-sm mb-4">
      <div class="flex items-center gap-2 text-white/50">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-white/30" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
        </svg>
        <span>{car.month}.{car.year}</span>
      </div>
      <div class="flex items-center gap-2 text-white/50">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-white/30" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
        </svg>
        <span class="truncate">{car.fuel}</span>
      </div>
      <div class="flex items-center gap-2 text-white/50">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-white/30" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0121 18.382V7.618a1 1 0 01-.447-.894L15 4m0 13V4m0 0L9 7" />
        </svg>
        <span>{car.mileage}</span>
      </div>
      <div class="flex items-center gap-2 text-white/50">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-white/30" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" />
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
        </svg>
        <span class="truncate">{car.transmission}</span>
      </div>
    </div>
    
    <!-- Price -->
    <div class="pt-4 border-t border-white/5">
      <span class="text-white font-bold text-lg">{car.price}.–</span>
    </div>
  </div>
</a>

<style>
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
