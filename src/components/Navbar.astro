---
const navLinks = [
  { href: '/', label: 'Accueil' },
  { href: '/#about', label: 'À Propos' },
  { href: '/#services', label: 'Services' },
  { href: '/achat', label: 'Nos Voitures' },
];
---

<header class="fixed top-0 left-0 right-0 z-50 bg-bg/75 backdrop-blur-md border-b border-white/5">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-20">
      <!-- Logo -->
      <a href="/" class="flex items-center">
        <img src="/assets/BLM - logo.png" alt="BLM CARS" class="h-12 w-auto" />
      </a>
      
      <!-- Desktop Navigation -->
      <nav class="hidden md:flex items-center gap-8">
        {navLinks.map(link => (
          <a 
            href={link.href}
            class="text-sm font-medium text-white/80 hover:text-primary transition-colors duration-200"
          >
            {link.label}
          </a>
        ))}
      </nav>
      
      <!-- CTA Button -->
      <div class="hidden md:block">
        <a 
          href="mailto:info@blmcars.ch"
          class="inline-flex items-center px-5 py-2.5 text-sm font-semibold text-bg bg-primary rounded-lg hover:bg-primary/90 transition-all duration-200"
        >
          Contactez-nous
        </a>
      </div>
      
      <!-- Mobile menu button -->
      <button 
        id="mobile-menu-btn"
        class="md:hidden p-2 text-white hover:text-primary transition-colors"
        aria-label="Menu"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>
  </div>
  
  <!-- Mobile Navigation -->
  <div id="mobile-menu" class="hidden md:hidden bg-bg border-t border-white/5">
    <div class="px-4 py-4 space-y-3">
      {navLinks.map(link => (
        <a 
          href={link.href}
          class="block py-2 text-sm font-medium text-white/80 hover:text-primary transition-colors"
        >
          {link.label}
        </a>
      ))}
      <a 
        href="mailto:info@blmcars.ch"
        class="block w-full text-center py-2.5 text-sm font-semibold text-bg bg-primary rounded-lg"
      >
        Contactez-nous
      </a>
    </div>
  </div>
</header>

<script>
  const mobileMenuBtn = document.getElementById('mobile-menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');
  
  mobileMenuBtn?.addEventListener('click', () => {
    mobileMenu?.classList.toggle('hidden');
  });
  
  // Close mobile menu when clicking on a link
  const mobileLinks = mobileMenu?.querySelectorAll('a');
  mobileLinks?.forEach(link => {
    link.addEventListener('click', () => {
      mobileMenu?.classList.add('hidden');
    });
  });
</script>
